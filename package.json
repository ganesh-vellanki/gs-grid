{
    "name": "@gs-grid/gs-grid",
    "version": "0.1.3",
    "description": "Framework-agnostic Web Component data grid with sorting, search, export, virtualization, and row selection",
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": true,
    "publishConfig": {
        "access": "public"
    },
    "repository": "https://github.com/ganesh-vellanki/gs-grid",
    "author": "velankiganesh@gmail.com",
    "license": "MIT",
    "private": false,
    "scripts": {
        "tsc:watch": "tsc --watch",
        "typedoc": "typedoc",
        "tsc": "tsc",
        "build:types": "tsc --declaration --declarationMap --emitDeclarationOnly --outDir ./dist",
        "build:package": "yarn clean:dist && yarn build:types && webpack --config webpack.lib.config.cjs",
        "webpack": "webpack",
        "rm": "rm",
        "docs": "typedoc --entryPointStrategy expand ./src --out ./demo/docs --readme none",
        "build:src": "yarn build:package && yarn webpack",
        "prestart": "yarn build && yarn docs && yarn copy:app",
        "build": "yarn build:src",
        "copy:app": "cp example/index.html demo/index.html & cp example/main.bundle.js demo/main.bundle.js & cp example/style.css demo/style.css",
        "start": "webpack serve",
        "clean:dist": "yarn rm -rf dist",
        "clean": "yarn clean:dist && yarn rm -rf demo/",
        "dev": "yarn build && yarn docs && concurrently --kill-others \"yarn tsc:watch\" \"yarn webpack --watch\" \"yarn webpack serve\"",
        "release": "standard-version",
        "prepublishOnly": "yarn build:package"
    },
    "husky": {
        "hooks": {}
    },
    "dependencies": {
        "rxjs": "^7.8.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "css-loader": "^6.10.0",
        "husky": "~4.3.0",
        "rmrf": "~2.0.2",
        "style-loader": "^3.3.0",
        "ts-loader": "^9.5.0",
        "@types/node": "^20.11.30",
        "typedoc": "^0.26.0",
        "typescript": "5.6.3",
        "webpack": "^5.90.0",
        "webpack-cli": "^5.1.0",
        "webpack-dev-server": "^4.15.0",
        "html-loader": "^4.2.0",
        "html-webpack-plugin": "^5.6.0",
        "sass": "^1.77.8",
        "sass-loader": "^16.0.1",
        "concurrently": "^8.2.0",
        "standard-version": "9.0.0"
    }
}
